# Copy to .env for local (host) runs: `cp .env.example .env` or `cp .env.example .env.development.local`.

# HTTP server
PORT=

# Postgres — set DATABASE_URL to override the individual parts below.
# DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_SSLMODE=
